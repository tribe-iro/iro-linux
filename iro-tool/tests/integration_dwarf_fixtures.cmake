if(NOT MULTI_HEADER MATCHES "#define IRO_OFFSETOF__struct_common_type__b 4ull")
  message(FATAL_ERROR "multi_unit fixture: missing offset for field b")
endif()

# Malformed object regression: parser must fail cleanly on invalid ELF payloads.
set(MALFORMED_OBJ "${WORK_ROOT}/malformed_probe.o")
file(WRITE "${MALFORMED_OBJ}" "not-an-elf")
execute_process(
  COMMAND "${CMAKE_COMMAND}" -E env "ASAN_OPTIONS=detect_leaks=0"
          "${LAYOUT_PARSE_BIN}"
          --manifest "${WORK_ROOT}/negative_enum/negative_enum.toml"
          --probe "${MALFORMED_OBJ}"
          --probe-cmd "${WORK_ROOT}/negative_enum/layout_negative_enum.probe.cmd"
          --outdir "${WORK_ROOT}/negative_enum"
          --emit
  RESULT_VARIABLE MALFORMED_RC
  OUTPUT_VARIABLE MALFORMED_OUT
  ERROR_VARIABLE MALFORMED_ERR
)
if(MALFORMED_RC EQUAL 0)
  message(FATAL_ERROR "Malformed object regression failed: invalid ELF unexpectedly succeeded")
endif()
if(NOT MALFORMED_ERR MATCHES "(not an ELF file|object too small for ELF header)")
  message(FATAL_ERROR
    "Malformed object regression failed: expected ELF-format diagnostic.\\n"
    "stdout:\\n${MALFORMED_OUT}\\n"
    "stderr:\\n${MALFORMED_ERR}")
endif()
