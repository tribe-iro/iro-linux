if(NOT NEG_EXPL_HEADER MATCHES "#define IRO_ENUM__enum_sample_enum__SAMPLE_NEG_BIG \\(-128ll\\)")
  message(FATAL_ERROR "negative_enum_explicit fixture: missing signed -128 emission")
endif()
if(NOT NEG_EXPL_HEADER MATCHES "#define IRO_ENUM__enum_sample_enum__SAMPLE_POS 7ull")
  message(FATAL_ERROR "negative_enum_explicit fixture: missing unsigned positive emission")
